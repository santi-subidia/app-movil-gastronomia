<?xml version="1.0" encoding="utf-8"?>
<!--
  Singleton business-configuration form.

  The root is a ScrollView so the form is usable on small screens. The
  ProgressBar, error text, and retry button overlay the form area:
  loading and error are mutually exclusive with the form, and the form
  fields and submit button share the same vertical column.

  ID conventions match the ViewBinding defaults (snake_case field
  names, no suffixes on the TextInputLayout wrappers — the wrappers
  are not referenced from Java).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/scroll_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Header -->
        <TextView
            android:id="@+id/text_header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/config_title"
            android:textAppearance="?attr/textAppearanceHeadline4"
            android:textColor="?attr/colorOnSurface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!--
          Form column. Wraps the 5 user-editable fields (every DTO
          field except the server-assigned id) and the submit button.
          Hidden during loading / error; shown on success.
        -->
        <LinearLayout
            android:id="@+id/form_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_header"
            tools:visibility="visible">

            <!-- nombreGastronomico -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_nombre_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/config_nombre_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_nombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="text|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- metodoPagoDefaultId -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_metodo_pago_id_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/config_metodo_pago_id_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_metodo_pago_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- metodoPagoDefaultNombre -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_metodo_pago_nombre_layout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/config_metodo_pago_nombre_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_metodo_pago_nombre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionNext"
                    android:inputType="text|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <!--
              Lat / Lng side-by-side row. Mirrors CrearPedidoFragment:
              two equally-weighted fields that share the row to keep
              the form compact.
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <!-- latitudPartida -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_latitud_layout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:hint="@string/config_latitud_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_latitud"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionNext"
                        android:inputType="numberDecimal|numberSigned" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- longitudPartida -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/input_longitud_layout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:hint="@string/config_longitud_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_longitud"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionDone"
                        android:inputType="numberDecimal|numberSigned" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Submit button. Label toggles between "Guardar" and "Actualizar" in code. -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/save_config" />
        </LinearLayout>

        <!--
          Loading state. Centered on the form area; the form column
          is hidden while this is visible.
        -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_header"
            tools:visibility="visible" />

        <!--
          Error state. Two views stacked vertically: a message and a
          retry button below it. Mirrors CajeroHome's pattern.
        -->
        <TextView
            android:id="@+id/text_error"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textAppearance="?attr/textAppearanceBody1"
            android:textColor="?attr/colorError"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/button_retry"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_header"
            app:layout_constraintVertical_bias="0.4"
            tools:text="@string/error_generic"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/retry"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_error"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
