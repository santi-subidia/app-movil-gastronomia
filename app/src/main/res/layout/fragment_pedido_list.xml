<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Filter chips strip -->
    <HorizontalScrollView
        android:id="@+id/filter_scroll"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/chip_todos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@color/chip_unselected_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="@string/all_orders"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="@color/chip_unselected_fg"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chip_pendiente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@color/chip_unselected_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="@string/status_pending"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="@color/chip_unselected_fg"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chip_en_preparacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@color/chip_unselected_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="@string/status_preparing"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="@color/chip_unselected_fg"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chip_listo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@color/chip_unselected_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="@string/status_ready"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="@color/chip_unselected_fg"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chip_en_camino"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@color/chip_unselected_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="@string/status_delivering"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="@color/chip_unselected_fg"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chip_entregado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/chip_unselected_bg"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:text="@string/status_delivered"
                android:textAppearance="?attr/textAppearanceBody2"
                android:textColor="@color/chip_unselected_fg"
                android:textStyle="bold" />

        </LinearLayout>

    </HorizontalScrollView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filter_scroll" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_pedidos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filter_scroll" />

    <TextView
        android:id="@+id/text_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_orders"
        android:textAppearance="?attr/textAppearanceBody1"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filter_scroll" />

    <TextView
        android:id="@+id/text_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBody1"
        android:textColor="?attr/colorError"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/button_retry"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filter_scroll"
        app:layout_constraintVertical_bias="0.4" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_retry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/retry"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_error" />

</androidx.constraintlayout.widget.ConstraintLayout>
